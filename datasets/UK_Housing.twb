          </datasources>
          <datasource-dependencies datasource='federated.00pf9qg1g73m3f17sm02n1n1sfus'>
            <column caption='Median Leasehold' datatype='real' name='[Calculation_1087056403269595136]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [tenure_group] = &apos;Leasehold&apos; THEN [median_price] END' />
            </column>
            <column caption='Median Freehold' datatype='real' name='[Calculation_1087056403270017025]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [tenure_group] =  &apos;Freehold&apos; THEN [median_price] END' />
            </column>
            <column caption='Median_Freehold_val' datatype='real' name='[Calculation_1087056403276931077]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_1087056403270017025])' />
